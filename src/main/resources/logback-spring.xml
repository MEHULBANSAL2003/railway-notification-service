<?xml version="1.0" encoding="UTF-8"?>

<!--
    Path: src/main/resources/logback-spring.xml

    WHY this file?
      Default Spring Boot logging doesn't include correlation IDs.
      This config tells Logback: "include the correlationId from MDC
      in every log line automatically."

    WHY logback-spring.xml (not logback.xml)?
      The "-spring" suffix lets us use <springProfile> tags to switch
      between dev and prod log formats. Plain logback.xml loads before
      Spring profiles are resolved, so profile switching won't work.
-->
<configuration>

  <!-- Read app name from application.yml -->
  <springProperty scope="context" name="APP_NAME"
                  source="spring.application.name"
                  defaultValue="railway-notification-service"/>

  <!--
      ════════════════════════════════════════
      DEV PROFILE — human-readable console logs
      ════════════════════════════════════════

      When you run with profile "dev" (or no profile, since dev is default),
      logs look like:

      14:30:22.456 [abc-123-def] INFO  c.r.auth.service.AuthService - Login attempt for priya@company.com
      14:30:22.512 [abc-123-def] DEBUG c.r.common.security.JwtUtil - Token generated for id=1

      Pattern breakdown:
        %d{HH:mm:ss.SSS}           → time only (date is noise in dev terminal)
        [%X{correlationId:-none}]   → correlation ID from MDC, "none" if not set
        %-5level                    → INFO/DEBUG/WARN/ERROR padded to 5 chars
        %logger{36}                → class name truncated to 36 chars
        %msg                       → your log message
        %n                         → newline
        %ex                        → stack trace (only printed if exception exists)
  -->
  <springProfile name="dev | default">

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} [%X{correlationId:-none}] %-5level %logger{36} - %msg%n%ex</pattern>
        <charset>UTF-8</charset>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>

    <!-- App packages — verbose in dev -->
    <logger name="com.railway" level="DEBUG" additivity="false">
      <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Spring Security — useful for debugging auth issues -->
    <logger name="org.springframework.security" level="INFO"/>

    <!-- Hibernate SQL — controlled via application-dev.yml -->
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="org.hibernate.type.descriptor.sql" level="TRACE"/>

  </springProfile>


  <!--
      ════════════════════════════════════════
      PROD PROFILE — structured JSON logs
      ════════════════════════════════════════

      When you run with profile "prod", every log line is a JSON object:

      {
        "timestamp": "2024-03-25T14:30:22.456Z",
        "level": "INFO",
        "service": "railway-auth-service",
        "correlationId": "abc-123-def",
        "logger": "c.r.auth.service.AuthService",
        "message": "Login attempt for priya@company.com",
        "thread": "http-nio-8080-exec-1"
      }

      WHY JSON in prod?
        Log aggregators (ELK, Datadog, CloudWatch, Grafana Loki)
        parse JSON natively. You can filter and search:
          correlationId = "abc-123" AND level = "ERROR"
        Impossible with plain text logs without regex hacks.

      WHY logstash-logback-encoder?
        Standard library for JSON logging. Automatically includes:
        - All MDC fields (correlationId, etc.)
        - Stack traces as JSON arrays (not messy multi-line text)
        - Thread name, logger name, timestamp in ISO format
  -->
  <springProfile name="prod">

    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <!-- Add service name to every log line -->
        <customFields>{"service":"${APP_NAME}"}</customFields>

        <!-- Include MDC fields (correlationId) automatically -->
        <includeMdcKeyName>correlationId</includeMdcKeyName>

        <!-- ISO timestamp format -->
        <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>

        <!-- Stack traces as single-line JSON, not multi-line mess -->
        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
          <maxDepthPerThrowable>30</maxDepthPerThrowable>
          <maxLength>2048</maxLength>
          <shortenedClassNameLength>36</shortenedClassNameLength>
          <!-- Only show our packages in stack traces, skip Spring internals -->
          <exclude>org\.springframework\..*</exclude>
          <exclude>sun\.reflect\..*</exclude>
          <exclude>java\.lang\.reflect\..*</exclude>
          <rootCauseFirst>true</rootCauseFirst>
        </throwableConverter>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="JSON_CONSOLE"/>
    </root>

    <logger name="com.railway" level="INFO" additivity="false">
      <appender-ref ref="JSON_CONSOLE"/>
    </logger>

    <!-- Silence noisy libraries in prod -->
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate.type.descriptor.sql" level="WARN"/>
    <logger name="org.apache.kafka" level="WARN"/>

  </springProfile>

</configuration>
